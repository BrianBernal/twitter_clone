{
  "name": "twitter-clone",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter twitter-clone-api dev",
    "dev:app": "pnpm --filter twitter-clone-app dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter twitter-clone-api build",
    "build:app": "pnpm --filter twitter-clone-app build",
    "start": "pnpm --filter twitter-clone-api start"
  }
}
